---
import ArticleLayout from '@/layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', (entry) => {
    return entry.data.lang === 'fr' && !entry.data.draft;
  });
  return articles.map((article) => ({
    // Strip 'fr/' prefix from the id for clean URLs
    params: { slug: article.id.replace(/^fr\//, '') },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  pubDate={article.data.pubDate}
  updatedDate={article.data.updatedDate}
  heroImage={article.data.heroImage}
  category={article.data.category}
  author={article.data.author}
  locale="fr"
  readingTime={article.data.readingTime}
  tags={article.data.tags}
  youtubeVideoId={article.data.youtubeVideoId}
>
  <Content />
</ArticleLayout>
