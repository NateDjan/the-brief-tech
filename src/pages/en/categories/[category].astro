---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import AdBanner from '@/components/AdBanner.astro';
import Newsletter from '@/components/Newsletter.astro';
import { t } from '@/i18n/utils';
import { getCollection } from 'astro:content';

const locale = 'en';

export function getStaticPaths() {
  return [
    { params: { category: 'tech' } },
    { params: { category: 'ai' } },
    { params: { category: 'business' } },
    { params: { category: 'crypto' } },
    { params: { category: 'startups' } },
  ];
}

const { category } = Astro.params;

const categoryLabel = t(locale, `categories.${category}`) || category;

const articles = (await getCollection('articles', (entry) => {
  return entry.data.lang === locale && !entry.data.draft && entry.data.category === category;
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const descriptions: Record<string, string> = {
  tech: "Latest tech news: Apple, Google, Samsung, Microsoft and more.",
  ai: "Artificial intelligence, machine learning, LLMs — all AI news decoded.",
  business: "Tech business, investing, tech stocks, funding rounds and financial analysis.",
  crypto: "Bitcoin, Ethereum, DeFi, Web3 — essential crypto news.",
  startups: "Innovative startups: funding rounds, launches and trends.",
};
---

<BaseLayout 
  title={`${categoryLabel} — The Brief`}
  description={descriptions[category!] || `${categoryLabel} articles on The Brief`}
  locale={locale}
>
  <div class="container" style="padding-top: 3rem;">
    <div class="section-header" style="margin-bottom: 2rem;">
      <h1 style="font-size: 2rem;">
        <span class={`badge badge-${category}`} style="font-size: 0.9rem; vertical-align: middle; margin-right: 0.5rem;">
          {categoryLabel}
        </span>
      </h1>
      <p style="color: var(--text-secondary); margin-top: 0.5rem;">
        {descriptions[category!]}
      </p>
    </div>

    {articles.length === 0 && (
      <div style="text-align: center; padding: 4rem 1rem;">
        <p style="font-size: 1.2rem; color: var(--text-secondary);">
          No articles in this category yet.
        </p>
        <p style="margin-top: 1rem;">
          <a href="/en/" style="color: var(--accent);">← Back to home</a>
        </p>
      </div>
    )}

    <div class="grid grid-3">
      {articles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate}
          category={article.data.category}
          slug={article.id}
          heroImage={article.data.heroImage}
          readingTime={article.data.readingTime}
          locale={locale}
        />
      ))}
    </div>

    <AdBanner format="horizontal" />
    <Newsletter locale={locale} />
  </div>
</BaseLayout>
