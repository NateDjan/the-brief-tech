---
import { t, getLocalizedPath, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={getLocalizedPath('/', locale)} class="logo">
          <span class="logo-icon">TB</span>
          <span>The Brief</span>
        </a>
        <p>{t(locale, 'footer.about')}</p>
      </div>

      <div class="footer-col">
        <h4>{t(locale, 'categories.tech')}</h4>
        <a href={getLocalizedPath('/categories/tech', locale)}>{t(locale, 'nav.tech')}</a>
        <a href={getLocalizedPath('/categories/ai', locale)}>{t(locale, 'nav.ai')}</a>
        <a href={getLocalizedPath('/categories/business', locale)}>{t(locale, 'nav.business')}</a>
        <a href={getLocalizedPath('/categories/crypto', locale)}>{t(locale, 'nav.crypto')}</a>
      </div>

      <div class="footer-col">
        <h4>{t(locale, 'footer.links')}</h4>
        <a href={getLocalizedPath('/about', locale)}>{t(locale, 'nav.about')}</a>
        <a href={getLocalizedPath('/privacy', locale)}>{t(locale, 'footer.privacy')}</a>
        <a href={getLocalizedPath('/legal', locale)}>{t(locale, 'footer.legal')}</a>
        <a href={getLocalizedPath('/contact', locale)}>{t(locale, 'footer.contact')}</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>{t(locale, 'footer.copyright')}</span>
      <div class="flex" style="gap: var(--space-md);">
        <a href="https://twitter.com/thebrief_tech" target="_blank" rel="noopener" aria-label="Twitter/X">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://linkedin.com/company/thebrief-tech" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
